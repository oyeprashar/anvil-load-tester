# ── LLM Configuration ─────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored — NEVER commit it to GitHub.
#
# Leave LLM_PROVIDER blank to disable AI summaries entirely.
# Anvil works fully without it.

LLM_PROVIDER=        # openai | anthropic | ollama | mock (mock = local testing, no API key needed)
LLM_API_KEY=         # your API key (not required for ollama)
LLM_MODEL=           # optional — uses provider default if blank
                     #   openai    → gpt-4o-mini
                     #   anthropic → claude-haiku-4-5-20251001
                     #   ollama    → llama3
LLM_BASE_URL=        # optional — override endpoint (useful for ollama or proxies)
                     #   ollama default: http://localhost:11434
