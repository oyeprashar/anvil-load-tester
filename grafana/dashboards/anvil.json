{
  "id": null,
  "uid": "anvil-main",
  "title": "Anvil — Load Testing Framework",
  "description": "Observability for Anvil itself: active runs, API latency, Go runtime health.",
  "refresh": "10s",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active Runs",
      "description": "k6 subprocesses currently running",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "anvil_active_runs",
        "refId": "A",
        "instant": true
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red",    "value": 8 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Runs Completed",
      "description": "Total successful runs since last restart",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "anvil_runs_total{status=\"completed\"}",
        "refId": "A",
        "instant": true
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "green", "mode": "fixed" }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Runs Failed",
      "description": "Total failed runs since last restart",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "anvil_runs_total{status=\"failed\"}",
        "refId": "A",
        "instant": true
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Goroutines",
      "description": "Live Go goroutine count",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "go_goroutines{job=\"anvil-backend\"}",
        "refId": "A",
        "instant": true
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red",    "value": 500 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Goroutines over time",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "go_goroutines{job=\"anvil-backend\"}",
        "legendFormat": "goroutines",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Heap memory allocated (bytes)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "go_memstats_alloc_bytes{job=\"anvil-backend\"}",
        "legendFormat": "heap alloc",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Anvil API — request rate (req/s)",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "sum(rate(anvil_http_requests_total[1m])) by (path)",
        "legendFormat": "{{path}}",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Anvil API — p95 request latency",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "histogram_quantile(0.95, sum(rate(anvil_http_request_duration_seconds_bucket[1m])) by (le, path))",
        "legendFormat": "p95 {{path}}",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    }
  ]
}
